<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- 清空代理設定，繞過系統代理直連 nuget.org -->
    <add key="http_proxy" value="" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>

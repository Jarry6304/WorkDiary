<Window x:Class="WorkDiary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorkDiary" Height="780" Width="900"
        MinHeight="600" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- 透明 Ghost 按鈕 -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#24292E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F2F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E1E4E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 藍色強調按鈕 -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006CBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>                          <!-- 頂部標題 + 搜尋列 -->
            <RowDefinition x:Name="EditorRow" Height="*"/>         <!-- 文字編輯區 -->
            <RowDefinition x:Name="AttachmentRow" Height="220"/>   <!-- 附件區 -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════
             頂部：緊湊標題列（Logo ｜ 搜尋 ｜ 導航）
             ════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E1E4E8"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Logo -->
                    <ColumnDefinition Width="*"/>     <!-- 搜尋（置中）-->
                    <ColumnDefinition Width="Auto"/>  <!-- 導航按鈕 -->
                </Grid.ColumnDefinitions>

                <!-- 面板切換按鈕（文字顯示目標模式）-->
                <Button x:Name="ModeToggleButton"
                        Grid.Column="0"
                        Content="📋  瀏覽模式"
                        FontSize="15" FontWeight="Bold"
                        Foreground="#0078D4"
                        Style="{StaticResource GhostButton}"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Click="ModeToggleButton_Click"/>

                <!-- 搜尋框（置中）-->
                <Grid Grid.Column="1"
                      x:Name="SearchContainer"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="280">
                    <Border Background="#F0F2F5"
                            CornerRadius="6"
                            Padding="10,6"
                            BorderBrush="Transparent"
                            BorderThickness="1.5">
                        <Grid>
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="13"
                                     FontFamily="Microsoft JhengHei UI, Segoe UI"
                                     VerticalAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown"
                                     GotFocus="SearchBox_GotFocus"
                                     LostFocus="SearchBox_LostFocus"/>
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="🔍  搜尋記錄關鍵字..."
                                       Foreground="#B0B5BC"
                                       FontSize="13"
                                       FontFamily="Microsoft JhengHei UI, Segoe UI"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 搜尋結果 Popup -->
                    <Popup x:Name="SearchResultsPopup"
                           PlacementTarget="{Binding ElementName=SearchContainer}"
                           Placement="Bottom"
                           StaysOpen="False"
                           Width="280">
                        <Border Background="White"
                                BorderBrush="#D0D5DB"
                                BorderThickness="1"
                                CornerRadius="0,0,6,6"
                                MaxHeight="230">
                            <ListBox x:Name="SearchResultsListBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="SearchResult_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DateLabel}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="#24292E"/>
                                            <TextBlock Text="{Binding Preview}"
                                                       Foreground="#9EA3A8"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <!-- 導航按鈕（瀏覽模式下隱藏）-->
                <StackPanel x:Name="NavButtonsPanel"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="PrevDayButton"
                            Content="◀"
                            Style="{StaticResource GhostButton}"
                            Click="PrevDayButton_Click"
                            ToolTip="前一天"
                            Margin="0,0,2,0"/>
                    <Button x:Name="NextDayButton"
                            Content="▶"
                            Style="{StaticResource GhostButton}"
                            Click="NextDayButton_Click"
                            ToolTip="後一天"
                            Margin="0,0,8,0"/>
                    <Button x:Name="CalendarToggleButton"
                            Click="CalendarToggleButton_Click"
                            Style="{StaticResource AccentButton}"
                            ToolTip="點擊開啟 / 關閉月曆"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             文字編輯區
             ════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E1E4E8"
                BorderThickness="0,0,0,1"
                Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 日期標題（可收起觸發）-->
                    <RowDefinition Height="Auto"/>  <!-- 標籤列（可收起）-->
                    <RowDefinition Height="*"/>     <!-- 編輯器（可收起）-->
                    <RowDefinition Height="Auto"/>  <!-- 字數列（可收起）-->
                </Grid.RowDefinitions>

                <!-- 日期標題列（點擊收起 / 展開）-->
                <Border Grid.Row="0"
                        Background="#FAFAFA"
                        BorderBrush="#E1E4E8"
                        BorderThickness="0,0,0,1"
                        Padding="12,10"
                        Cursor="Hand"
                        MouseLeftButtonUp="DateHeader_Toggle">
                    <DockPanel>
                        <!-- 折疊方向指示 -->
                        <TextBlock x:Name="CollapseChevron"
                                   Text="▼"
                                   DockPanel.Dock="Left"
                                   Foreground="#B0B5BC"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <!-- 置頂星號（右側）-->
                        <Button x:Name="PinButton"
                                Content="☆"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButton}"
                                Click="PinButton_Click"
                                FontSize="16"
                                Foreground="#C0C4CC"
                                ToolTip="置頂此日記"
                                Padding="6,2"
                                Margin="4,0,0,0"/>
                        <!-- 日期文字 -->
                        <TextBlock x:Name="DateHeaderText"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#24292E"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- 標籤列（可收起）-->
                <Border Grid.Row="1"
                        x:Name="TagsBar"
                        Background="#FAFAFA"
                        BorderBrush="#E1E4E8"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <WrapPanel x:Name="TagsWrapPanel"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 編輯器（可收起）-->
                <Grid Grid.Row="2" x:Name="EditorGrid">
                    <RichTextBox x:Name="DiaryRichTextBox"
                                 Padding="16,12"
                                 FontSize="14"
                                 FontFamily="Microsoft JhengHei UI, Segoe UI"
                                 BorderThickness="0"
                                 Background="White"
                                 Foreground="#24292E"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextChanged="DiaryRichTextBox_TextChanged">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0,0,0,2"/>
                                <Setter Property="LineHeight" Value="24"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                    <TextBlock x:Name="EditorPlaceholder"
                               Text="在此輸入今日工作記錄..."
                               Foreground="#C0C4CC"
                               FontSize="14"
                               FontFamily="Microsoft JhengHei UI, Segoe UI"
                               Margin="20,14,0,0"
                               VerticalAlignment="Top"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- 字數統計（可收起）-->
                <Border Grid.Row="3"
                        x:Name="WordCountBar"
                        Background="#FAFAFA"
                        BorderBrush="#E1E4E8"
                        BorderThickness="0,1,0,0"
                        Padding="16,4">
                    <TextBlock x:Name="WordCountText"
                               Text=""
                               Foreground="#9EA3A8"
                               FontSize="11"
                               HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             附件區（收起時整區隱藏）
             ════════════════════════════════════════ -->
        <Border Grid.Row="2"
                x:Name="AttachmentArea"
                Background="White"
                Margin="0,8,0,0"
                BorderBrush="#E1E4E8"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 附件標題列 -->
                <Border Grid.Row="0"
                        Background="#FAFAFA"
                        BorderBrush="#E1E4E8"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <TextBlock Text="📎  附件"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#24292E"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 拖曳區 / 附件清單 -->
                <Border Grid.Row="1"
                        x:Name="DropZoneBorder"
                        AllowDrop="True"
                        Drop="DropZone_Drop"
                        DragEnter="DropZone_DragEnter"
                        DragOver="DropZone_DragOver"
                        DragLeave="DropZone_DragLeave"
                        Background="Transparent"
                        BorderThickness="2"
                        BorderBrush="Transparent"
                        CornerRadius="4"
                        Margin="8,6">
                    <Grid>
                        <!-- 空白提示 -->
                        <StackPanel x:Name="DropHint"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="📂"
                                       FontSize="32"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="直接拖曳檔案到此處"
                                       Foreground="#9EA3A8" FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="支援：Excel、PDF、PPT、TXT、JPG、PNG"
                                       Foreground="#C0C4CC" FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 附件清單 -->
                        <ListView x:Name="AttachmentListView"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Visibility="Collapsed"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  MouseDoubleClick="AttachmentListView_MouseDoubleClick"
                                  KeyDown="AttachmentListView_KeyDown">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="開啟檔案"
                                              Click="AttachmentMenu_Open"/>
                                    <MenuItem Header="在資料夾中顯示"
                                              Click="AttachmentMenu_ShowInFolder"/>
                                    <Separator/>
                                    <MenuItem Header="刪除附件"
                                              Click="AttachmentMenu_Delete"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="4,6"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="#24292E"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FileSize}"
                                                   Foreground="#9EA3A8"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!-- ════════════════════════════════════════
             瀏覽面板（覆蓋 Row 1+2，預設隱藏）
             ════════════════════════════════════════ -->
        <ScrollViewer x:Name="BrowseScrollViewer"
                      Grid.Row="1" Grid.RowSpan="2"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,8,0,0"
                      Background="White">
            <StackPanel x:Name="BrowseEntriesPanel"/>
        </ScrollViewer>
    </Grid>
</Window>
